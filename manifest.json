{
  "manifest_version": 3,
  "name": "Jeddy",
  "version": "0.1.0",
  "description": "Suggests resume-based answers while filling job applications.",
  "permissions": ["storage", "sidePanel", "tabs"],
  "side_panel": {
    "default_path": "popup.html"
  },
  "host_permissions": ["<all_urls>", "https://api.openai.com/*", "https://api.mistral.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Jeddy",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
